rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // 1. Global Default Deny Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Global Helper Functions ---
    
    // Checks if the user is authenticated
    function isSignedIn() {
      return request.auth != null;
    }

    // Checks if the user is the owner of the document being requested
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Prevent ID Poisoning by verifying document ID format and size
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // --- Collection Matching and Access Rules ---

    // Users and Profiles collection. Read is open to any signed-in user (not
    // just the owner) so real circle co-members can see each other's name,
    // avatar, and streak — write stays owner-only.
    match /profiles/{userId} {
      allow read: if isSignedIn();
      allow write: if isOwner(userId);
    }

    // Memory plans collection
    match /memoryPlans/{userId} {
      allow read, write: if isOwner(userId);
    }

    // User verses collection (nested under users/{userId})
    match /users/{userId}/verses/{verseId} {
      allow read, write: if isOwner(userId);
    }

    // Unified Memory Queue collection
    match /users/{userId}/memoryQueue/{verseId} {
      allow read, write: if isOwner(userId);
    }

    // Voice recordings of chapter recitations. This is always the private,
    // owner-only source of truth regardless of sharedVisibility — sharing
    // works by ALSO writing a denormalized copy to sharedRecordings (below),
    // never by opening this collection itself up to other users.
    match /users/{userId}/recordings/{recordingId} {
      allow read, write: if isOwner(userId);
    }

    // Denormalized, read-only-to-others copy of a recording once its owner
    // sets sharedVisibility to 'circle' or 'public'. Firestore rules can't
    // cheaply check "is this reader a co-member of ANY of the owner's
    // circles" (no loops over arbitrary-length lists), so instead of a live
    // check, sharedWithUids is a snapshot of exactly who could see it at
    // share time (circle co-members + friends) — checked with the built-in
    // hasAny() array operator, no loop needed. A later-joining circle member
    // won't retroactively see older shares; new shares include them.
    match /sharedRecordings/{recordingId} {
      allow read: if isSignedIn() &&
        (resource.data.visibility == 'public' ||
         isOwner(resource.data.ownerId) ||
         resource.data.sharedWithUids.hasAny([request.auth.uid]));
      allow create, update: if isSignedIn() && request.resource.data.ownerId == request.auth.uid;
      allow delete: if isSignedIn() && resource.data.ownerId == request.auth.uid;
    }

    // Shared plans collection for community memory plans
    match /sharedPlans/{planId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    // Real, mutual, persistent friend connections — independent of circle
    // membership (unlike circleFriends, which is just live-recomputed
    // co-membership). A friendship is two docs (one per direction), written
    // together by whichever side accepts — allow create/delete by either the
    // path owner (userId) or the referenced friend (friendUid) so one
    // client-side batch can write/remove both sides atomically.
    match /profiles/{userId}/friends/{friendUid} {
      allow read: if isSignedIn();
      allow create, delete: if isOwner(userId) || isOwner(friendUid);
      allow update: if false;
    }

    // Friend requests: created by the sender, only the recipient can
    // accept/decline (update), either side can read or cancel/clear it.
    match /friendRequests/{requestId} {
      allow read: if isSignedIn() && (resource.data.fromUid == request.auth.uid || resource.data.toUid == request.auth.uid);
      allow create: if isSignedIn() && request.resource.data.fromUid == request.auth.uid;
      allow update: if isSignedIn() && resource.data.toUid == request.auth.uid;
      allow delete: if isSignedIn() && (resource.data.fromUid == request.auth.uid || resource.data.toUid == request.auth.uid);
    }

    // Accountability nudges (friend-only, sender-composed custom message,
    // deliberately separate from any messaging system). Immutable log except
    // the recipient may mark their own copy read, or delete it from their inbox.
    match /accountabilityNudges/{nudgeId} {
      allow read: if isSignedIn() && (resource.data.fromUid == request.auth.uid || resource.data.toUid == request.auth.uid);
      allow create: if isSignedIn() && request.resource.data.fromUid == request.auth.uid;
      allow update: if isSignedIn() && resource.data.toUid == request.auth.uid
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read']);
      allow delete: if isSignedIn() && resource.data.toUid == request.auth.uid;
    }

    // Sender's own private bookkeeping of "when did I last nudge this
    // friend" -- purely mine, nobody else ever reads or writes it, so this
    // is the simple owner-only shape (no cross-user complexity needed at all).
    match /profiles/{userId}/accountabilitySentLog/{friendUid} {
      allow read, write: if isOwner(userId);
    }

    // Recipient's today-so-far received-nudge counter -- the one doc in this
    // feature that a NON-owner (any friend about to send a nudge) needs to
    // read (to show/enforce the cap before sending) and increment. Deliberately
    // narrow: only `count`/`dateKey` may change, and count may only go up by
    // exactly 1 per write (or reset to 1 on a new dateKey) -- no Cloud
    // Functions in this project, so this is the same "reasonable client trust,
    // not paranoid" posture as the rest of this file, not airtight server
    // enforcement.
    match /profiles/{userId}/accountabilityMeta/counter {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.count == 1;
      allow update: if isSignedIn()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['count', 'dateKey'])
        && (request.resource.data.count == 1 || request.resource.data.count == resource.data.count + 1);
    }

    // Messaging: 1:1 DM threads gated by "friend OR shared circle membership",
    // re-checked server-side on every message (not just thread creation) --
    // this is what makes a thread go read-only the moment that gating
    // relationship disappears, with no separate "active" flag to trust.
    // threadId is the two participant uids sorted + joined with '_'.
    function isFriendOf(a, b) {
      return exists(/databases/$(database)/documents/profiles/$(a)/friends/$(b));
    }

    function sharesCircleWith(a, b) {
      return get(/databases/$(database)/documents/profiles/$(a)).data.get('circleIds', [])
        .hasAny(get(/databases/$(database)/documents/profiles/$(b)).data.get('circleIds', []));
    }

    function dmGated(a, b) {
      return isFriendOf(a, b) || sharesCircleWith(a, b);
    }

    match /dmThreads/{threadId} {
      allow read: if isSignedIn() && request.auth.uid in resource.data.participantUids;
      allow create: if isSignedIn()
        && request.resource.data.participantUids.size() == 2
        && request.auth.uid in request.resource.data.participantUids
        && dmGated(request.resource.data.participantUids[0], request.resource.data.participantUids[1]);
      // Only the thread preview fields change after creation -- participants
      // never change on an existing thread.
      allow update: if isSignedIn() && request.auth.uid in resource.data.participantUids
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['lastMessage', 'lastMessageAt']);

      match /messages/{messageId} {
        allow read: if isSignedIn()
          && request.auth.uid in get(/databases/$(database)/documents/dmThreads/$(threadId)).data.participantUids;
        allow create: if isSignedIn() && request.resource.data.fromUid == request.auth.uid
          && request.auth.uid in get(/databases/$(database)/documents/dmThreads/$(threadId)).data.participantUids
          && dmGated(get(/databases/$(database)/documents/dmThreads/$(threadId)).data.participantUids[0],
                     get(/databases/$(database)/documents/dmThreads/$(threadId)).data.participantUids[1]);
        allow update, delete: if false;
      }
    }

    // Group chat auto-tied to a Circle -- members only, immutable messages.
    match /circles/{circleId}/messages/{messageId} {
      allow read: if isSignedIn()
        && exists(/databases/$(database)/documents/circles/$(circleId)/members/$(request.auth.uid));
      allow create: if isSignedIn() && request.resource.data.fromUid == request.auth.uid
        && exists(/databases/$(database)/documents/circles/$(circleId)/members/$(request.auth.uid));
      allow update, delete: if false;
    }

    // Real memorization-milestone activity feed (Community). Read is open to
    // any signed-in user (matches profiles' posture — nothing in this app is
    // friend-scoped at the rule level, just at the client query level).
    // Immutable event log: only the author can create their own event, and
    // nobody can edit/delete one after the fact.
    match /activityEvents/{eventId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.uid == request.auth.uid;
      allow update, delete: if false;
    }

    // Scripture Circles: community/small-group pacing circles. No Cloud
    // Functions in this project, so private-circle invite codes are checked
    // client-side, not server-side — acceptable at this app's small-group
    // trust level. Only the original creator is ever a 'leader' (ownerId) —
    // there's no promote/demote feature yet, so member docs are immutable
    // after creation.
    match /circles/{circleId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.ownerId == request.auth.uid;
      allow update, delete: if isSignedIn() && resource.data.ownerId == request.auth.uid;

      match /members/{memberId} {
        allow read: if isSignedIn();
        allow create: if isOwner(memberId); // self-service join
        allow delete: if isOwner(memberId) // self-service leave
          || get(/databases/$(database)/documents/circles/$(circleId)).data.ownerId == request.auth.uid; // or owner kicks
        allow update: if false;
      }

      match /groupPlans/{planId} {
        allow read: if isSignedIn();
        allow write: if isSignedIn() && get(/databases/$(database)/documents/circles/$(circleId)).data.ownerId == request.auth.uid;
      }
    }

    // Scripture text library: translations/{translationId} (metadata) and
    // translations/{translationId}/books/{bookId}/chapters/{chapterNumber}
    // (verse text). Readable by everyone (including signed-out users browsing
    // scripture), never writable from the client — populated only by the
    // admin import script running with a service account, which bypasses
    // these rules entirely.
    match /translations/{translationId} {
      allow read: if true;
      allow write: if false;

      match /books/{bookId}/chapters/{chapterId} {
        allow read: if true;
        allow write: if false;
      }
    }

  }
}
