rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    // Global Default Deny Safety Net
    match /{allPaths=**} {
      allow read, write: if false;
    }

    // Voice recordings of chapter recitations: recordings/{userId}/{recordingId}.<ext>
    // Private to the owner (mirrors firestore.rules' users/{userId}/recordings) —
    // capped at 50MB and audio-only to bound storage cost and reject non-audio uploads.
    match /recordings/{userId}/{fileName} {
      allow read: if request.auth != null && request.auth.uid == userId;
      // create/update (i.e. uploads) go through request.resource's size/type
      // checks; delete has no request.resource (nothing is being written), so
      // it needs its own, simpler rule — otherwise those checks evaluate
      // against a null resource and every delete gets denied.
      allow create, update: if request.auth != null && request.auth.uid == userId
        && request.resource.size < 50 * 1024 * 1024
        && request.resource.contentType.matches('audio/.*');
      allow delete: if request.auth != null && request.auth.uid == userId;
    }
  }
}
